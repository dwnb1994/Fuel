# Template — copy เป็น .env แล้วใส่ค่าจริง
# (.env จะถูก ignore โดย git ส่วน .env.example commit ได้)

MES_EMAIL=your.email@thaidrill.co.th
MES_PASSWORD=your_mes_password_here

# Firebase refresh token (ดึงครั้งเดียวจาก browser console)
# 1. เปิด https://mes.systemtd.com/ → Login
# 2. F12 → Console:
#      const k = 'firebase:authUser:AIzaSyBXpxmaKmfjzNVtgO7cZtCXmPPwt6gv2xM:[DEFAULT]';
#      console.log(JSON.parse(sessionStorage.getItem(k)).stsTokenManager.refreshToken);
MES_REFRESH_TOKEN=your_refresh_token_here
